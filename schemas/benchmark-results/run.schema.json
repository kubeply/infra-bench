{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kubeply/infra-bench/schemas/benchmark-results/run.schema.json",
  "title": "InfraBench benchmark run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "dataset",
    "dataset_path",
    "infra_bench_commit",
    "harbor_version",
    "agent_harness",
    "model",
    "started_at",
    "finished_at",
    "summary",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "dataset_path": {
      "type": "string",
      "minLength": 1
    },
    "infra_bench_commit": {
      "type": "string",
      "minLength": 1
    },
    "harbor_version": {
      "type": ["string", "null"]
    },
    "agent_harness": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "name", "version"],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": ["string", "null"]
        }
      }
    },
    "started_at": {
      "type": ["string", "null"]
    },
    "finished_at": {
      "type": ["string", "null"]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_count",
        "passed",
        "failed",
        "score",
        "duration_sec",
        "cost_usd"
      ],
      "properties": {
        "task_count": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "duration_sec": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run", "results", "archive"],
      "properties": {
        "run": {
          "type": "string",
          "minLength": 1
        },
        "results": {
          "type": "string",
          "minLength": 1
        },
        "archive": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
